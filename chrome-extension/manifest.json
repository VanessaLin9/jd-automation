{
  "manifest_version": 3,
  "name": "JD Saver for Google Sheets",
  "description": "Save the current job description page to your own Google Sheet.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "identity",
    "identity.email",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://sheets.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "160405257245-pdcmsmttcv12cjjbi3dnkhscmh5ru7s8.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "action": {
    "default_title": "JD Saver",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
