{
  "manifest_version": 3,
  "name": "JD Saver for Google Sheets",
  "description": "Save the current job description page to your own Google Sheet.",
  "version": "0.1.2",
  "key": "",
  "permissions": [
    "activeTab",
    "identity",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://sheets.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "708074327166-2vk0mn8elapun8dm18igbe3llhvnu9en.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "action": {
    "default_title": "JD Saver",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
